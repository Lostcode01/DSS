{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "build easyx",
      "command": "C:/mingw64/bin/g++.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}.exe",
        "-leasyx",
        "-lgdi32",
        "-limm32"
      ],
      "options": { "cwd": "C:/mingw64/bin" },
      "problemMatcher": ["$gcc"],
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}
