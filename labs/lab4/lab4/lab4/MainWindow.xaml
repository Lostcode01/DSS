<Window x:Class="lab4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Модель многоуровневого доступа Белла-ЛаПадула" 
        Height="750" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Управление доступом (Модель Белла-ЛаПадула)" Grid.Row="0" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Список пользователей -->
                <TextBlock Text="1. Пользователи:" Grid.Row="0" Grid.Column="0" Margin="5" FontWeight="Bold"/>
                <ListBox x:Name="lstUsers" Grid.Row="1" Grid.Column="0" Grid.RowSpan="3" Height="120" Margin="5" 
                         SelectionChanged="lstUsers_SelectionChanged"/>

                <!-- Информация о привилегии пользователя -->
                <TextBlock x:Name="txtUserPrivilege" Grid.Row="4" Grid.Column="0" Margin="5" 
                           FontStyle="Italic" Foreground="DarkBlue"/>

                <!-- Кнопка редактирования матрицы -->
                <Button x:Name="btnEditMatrix" Grid.Row="5" Grid.Column="0" Content="2. Редактировать матрицу" 
                        Margin="5" Padding="5" Click="btnEditMatrix_Click" IsEnabled="False"/>

                <!-- Список объектов -->
                <TextBlock Text="3. Объекты:" Grid.Row="0" Grid.Column="1" Margin="5" FontWeight="Bold"/>
                <ListBox x:Name="lstObjects" Grid.Row="1" Grid.Column="1" Grid.RowSpan="3" Height="120" Margin="5"
                         SelectionChanged="lstObjects_SelectionChanged"/>

                <!-- Информация о привилегии объекта -->
                <TextBlock x:Name="txtObjectPrivilege" Grid.Row="4" Grid.Column="1" Margin="5" 
                           FontStyle="Italic" Foreground="DarkBlue"/>

                <!-- Информация о правах доступа -->
                <TextBlock x:Name="txtAccessInfo" Grid.Row="5" Grid.Column="1" Margin="5" 
                           TextWrapping="Wrap" FontStyle="Italic"/>

                <!-- Поле значения объекта -->
                <TextBlock Text="4. Значение объекта:" Grid.Row="0" Grid.Column="2" Margin="5" FontWeight="Bold"/>
                <TextBox x:Name="txtObjectValue" Grid.Row="1" Grid.Column="2" Grid.RowSpan="4" 
                         Margin="5" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         IsReadOnly="True" TextChanged="txtObjectValue_TextChanged"/>

                <!-- Кнопки работы с буфером -->
                <GroupBox Header="Операции с буфером" Grid.Row="0" Grid.Column="3" Grid.RowSpan="6" Margin="5">
                    <StackPanel>
                        <TextBlock Text="Буфер обмена:" Margin="5" FontWeight="Bold"/>
                        <TextBox x:Name="txtBuffer" Height="80" Margin="5" TextWrapping="Wrap" 
                                 AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True"/>

                        <TextBlock x:Name="txtBufferPrivilege" Margin="5" FontStyle="Italic" 
                                   Foreground="DarkBlue"/>

                        <Separator Margin="5"/>

                        <Button x:Name="btnCopyToBuffer" Content="6. Копировать ИЗ объекта в буфер" 
                                Margin="5" Padding="5" Click="btnCopyToBuffer_Click" IsEnabled="False"/>

                        <Button x:Name="btnCopyFromBuffer" Content="5. Копировать ИЗ буфера в объект" 
                                Margin="5" Padding="5" Click="btnCopyFromBuffer_Click" IsEnabled="False"/>

                        <Separator Margin="5"/>

                        <TextBlock Text="Правила Белла-ЛаПадула:" Margin="5" FontWeight="Bold" 
                                   Foreground="DarkRed"/>
                        <TextBlock Text="• No Read Up (простое условие)" Margin="5,0,0,0" 
                                   FontStyle="Italic" FontSize="11"/>
                        <TextBlock Text="• No Write Down (свойство *-защиты)" Margin="5,0,0,0" 
                                   FontStyle="Italic" FontSize="11"/>
                    </StackPanel>
                </GroupBox>
            </Grid>
        </GroupBox>

        <!-- Таблица прав доступа -->
        <GroupBox Header="Матрица прав доступа и уровни привилегий" Grid.Row="1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <DataGrid x:Name="dgAccessMatrix" AutoGenerateColumns="False" 
                          CanUserAddRows="False" IsReadOnly="True"
                          HeadersVisibility="All">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Пользователь" Binding="{Binding UserName}" Width="120"/>
                        <DataGridTextColumn Header="Уровень" Binding="{Binding UserLevel}" Width="60"/>
                        <DataGridTextColumn Header="Адм. права" Binding="{Binding AdminRights}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </ScrollViewer>
        </GroupBox>
    </Grid>
</Window>