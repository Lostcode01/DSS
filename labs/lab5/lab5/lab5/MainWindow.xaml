<Window x:Class="lab5.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Лабораторная работа №5 - Маршрутная перестановка (5×8)" 
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель управления -->
        <GroupBox Header="Управление" Grid.Row="0" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Входной текст -->
                <TextBlock Text="Исходный текст:" Grid.Row="0" Grid.Column="0" Margin="5" FontWeight="Bold"/>
                <TextBox x:Name="txtInput" Grid.Row="1" Grid.Column="0" Height="80" Margin="5" 
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                <!-- Ключ (маршрут) -->
                <TextBlock Text="Маршрут чтения:" Grid.Row="0" Grid.Column="1" Margin="5" FontWeight="Bold"/>
                <ComboBox x:Name="cmbRoute" Grid.Row="1" Grid.Column="1" Margin="5" VerticalAlignment="Center">
                    <ComboBoxItem Content="Змейка (горизонтальная)" IsSelected="True"/>
                    <ComboBoxItem Content="Спираль"/>
                    <ComboBoxItem Content="Диагональный"/>
                </ComboBox>

                <!-- Кнопки операций -->
                <StackPanel Grid.Row="1" Grid.Column="2" Margin="5" VerticalAlignment="Center">
                    <Button x:Name="btnEncrypt" Content="Зашифровать" Margin="0,0,0,5" 
                            Padding="10,5" Click="btnEncrypt_Click"/>
                    <Button x:Name="btnDecrypt" Content="Расшифровать" Margin="0,0,0,5" 
                            Padding="10,5" Click="btnDecrypt_Click"/>
                    <Button x:Name="btnClear" Content="Очистить" 
                            Padding="10,5" Click="btnClear_Click"/>
                </StackPanel>

                <!-- Результат -->
                <TextBlock Text="Результат:" Grid.Row="2" Grid.Column="0" Margin="5" FontWeight="Bold"/>
                <TextBox x:Name="txtOutput" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" 
                         Height="60" Margin="5" TextWrapping="Wrap" 
                         VerticalScrollBarVisibility="Auto"/>

                <!-- Статистика -->
                <StackPanel Grid.Row="2" Grid.Column="2" Margin="5" VerticalAlignment="Center">
                    <TextBlock x:Name="txtStats" Text="Символов: 0" FontWeight="Bold"/>
                    <TextBlock x:Name="txtBlocks" Text="Блоков: 0" FontStyle="Italic"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Визуализация таблицы -->
        <GroupBox Header="Визуализация таблицы 5×8" Grid.Row="1" Margin="0,0,0,10">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Grid x:Name="gridTable" Margin="10"/>
            </ScrollViewer>
        </GroupBox>

    </Grid>
</Window>