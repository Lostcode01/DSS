<Window x:Class="DefenceModel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Модель дискреционного управления доступом HRU" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Управление доступом" Grid.Row="0" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Список пользователей -->
                <TextBlock Text="1. Пользователи:" Grid.Row="0" Grid.Column="0" Margin="5" FontWeight="Bold"/>
                <ListBox x:Name="lstUsers" Grid.Row="1" Grid.Column="0" Height="150" Margin="5" 
                         SelectionChanged="lstUsers_SelectionChanged"/>

                <!-- Кнопка редактирования матрицы -->
                <Button x:Name="btnEditMatrix" Grid.Row="2" Grid.Column="0" Content="2. Редактировать матрицу доступа" 
                        Margin="5" Padding="5" Click="btnEditMatrix_Click"/>

                <!-- Список объектов -->
                <TextBlock Text="3. Объекты:" Grid.Row="0" Grid.Column="1" Margin="5" FontWeight="Bold"/>
                <ListBox x:Name="lstObjects" Grid.Row="1" Grid.Column="1" Height="150" Margin="5"
                         SelectionChanged="lstObjects_SelectionChanged"/>

                <!-- Поле значения объекта -->
                <TextBlock Text="4. Значение объекта:" Grid.Row="0" Grid.Column="2" Margin="5" FontWeight="Bold"/>
                <TextBox x:Name="txtObjectValue" Grid.Row="1" Grid.Column="2" Grid.RowSpan="2" 
                         Margin="5" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         IsReadOnly="True"/>

                <!-- Информация о правах -->
                <TextBlock x:Name="txtAccessInfo" Grid.Row="2" Grid.Column="1" Margin="5" 
                           TextWrapping="Wrap" FontStyle="Italic"/>
            </Grid>
        </GroupBox>

        <!-- Таблица прав доступа -->
        <GroupBox Header="Матрица прав доступа" Grid.Row="1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <DataGrid x:Name="dgAccessMatrix" AutoGenerateColumns="False" 
                          CanUserAddRows="False" IsReadOnly="True"
                          HeadersVisibility="All">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Пользователь" Binding="{Binding UserName}" Width="120"/>
                        <DataGridTextColumn Header="Адм. права" Binding="{Binding AdminRights}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </ScrollViewer>
        </GroupBox>
    </Grid>
</Window>