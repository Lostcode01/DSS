<Window x:Class="DefenceModel.EditMatrixWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование матрицы доступа" Height="600" Width="900"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <!-- Вкладка управления пользователями -->
            <TabItem Header="Пользователи">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ListBox x:Name="lstEditUsers" Grid.Column="0" Margin="5"
                             SelectionChanged="lstEditUsers_SelectionChanged"/>

                    <StackPanel Grid.Column="1" Margin="5">
                        <TextBlock Text="Имя пользователя:" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtUserName" Margin="0,0,0,10"/>

                        <TextBlock Text="Административные права (0/1):" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbAdminRights" Margin="0,0,0,10">
                            <ComboBoxItem Content="0 - Нет прав" IsSelected="True"/>
                            <ComboBoxItem Content="1 - Есть права"/>
                        </ComboBox>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button x:Name="btnAddUser" Content="Добавить" Margin="0,0,10,0" 
                                    Padding="10,5" Click="btnAddUser_Click"/>
                            <Button x:Name="btnUpdateUser" Content="Обновить" Margin="0,0,10,0" 
                                    Padding="10,5" Click="btnUpdateUser_Click"/>
                            <Button x:Name="btnDeleteUser" Content="Удалить" 
                                    Padding="10,5" Click="btnDeleteUser_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Вкладка управления объектами -->
            <TabItem Header="Объекты">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ListBox x:Name="lstEditObjects" Grid.Column="0" Margin="5"
                             SelectionChanged="lstEditObjects_SelectionChanged"/>

                    <StackPanel Grid.Column="1" Margin="5">
                        <TextBlock Text="Имя объекта:" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtObjectName" Margin="0,0,0,10"/>

                        <TextBlock Text="Значение объекта:" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtObjectContent" Height="100" Margin="0,0,0,10" 
                                 TextWrapping="Wrap" AcceptsReturn="True"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button x:Name="btnAddObject" Content="Добавить" Margin="0,0,10,0" 
                                    Padding="10,5" Click="btnAddObject_Click"/>
                            <Button x:Name="btnUpdateObject" Content="Обновить" Margin="0,0,10,0" 
                                    Padding="10,5" Click="btnUpdateObject_Click"/>
                            <Button x:Name="btnDeleteObject" Content="Удалить" 
                                    Padding="10,5" Click="btnDeleteObject_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Вкладка прав доступа -->
            <TabItem Header="Права доступа">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="dgEditRights" AutoGenerateColumns="False" 
                              CanUserAddRows="False" Grid.Row="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Пользователь" Binding="{Binding UserName}" 
                                                IsReadOnly="True" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button Grid.Row="1" Content="Сохранить изменения прав" Margin="0,10,0,0" 
                            Padding="15,5" HorizontalAlignment="Left" Click="btnSaveRights_Click"/>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" Width="75" Margin="0,0,10,0" Padding="5" Click="btnOK_Click"/>
            <Button Content="Отмена" Width="75" Padding="5" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>